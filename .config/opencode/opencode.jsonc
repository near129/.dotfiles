{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "ask",
      "git branch *": "allow",
      "git config --get *": "allow",
      "git rev-parse *": "allow",
      "git worktree *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "sudo *": "deny",
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
  },
}
